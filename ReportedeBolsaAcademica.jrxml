<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="ReportedeBolsaAcademica" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b1ddef74-2796-4a6b-b996-66c2c0b83e7e">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="AliadoExterno" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<parameter name="CarreraSolicitada" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todas"]]></defaultValueExpression>
	</parameter>
	<parameter name="FechaInicioBolsaAcademica" class="java.sql.Timestamp"/>
	<parameter name="FechaFinBolsaAcademica" class="java.sql.Timestamp"/>
	<query language="SQL"><![CDATA[SELECT 
    oe.RazonSocial AS aliado,
    ol.Cargo AS vacante,
    COUNT(sp.CI) AS postulados,
    COUNT(CASE WHEN LOWER(sp.Resultado) IN ('en revisión', 'aceptado') THEN 1 END) AS avanzaron,
    COUNT(CASE WHEN LOWER(sp.Resultado) = 'aceptado' THEN 1 END) AS contratados,
    CASE 
        WHEN COUNT(sp.CI) > 0 THEN ROUND((COUNT(CASE WHEN LOWER(sp.Resultado) = 'aceptado' THEN 1 END)::NUMERIC / COUNT(sp.CI)::NUMERIC) * 100, 1)
        ELSE 0.0 
    END AS efectividad
FROM OrganizacionExterna oe
JOIN OportunidadLaboral ol ON oe.RIF = ol.RIF
LEFT JOIN SePostula sp ON ol.RIF = sp.RIF AND ol.FechaHoraOferta = sp.FechaHoraOferta
LEFT JOIN Egresado eg ON sp.CI = eg.CI
WHERE ol.FechaHoraOferta BETWEEN $P{FechaInicioBolsaAcademica} AND $P{FechaFinBolsaAcademica}
  AND ($P{AliadoExterno} = 'Todos' OR oe.RazonSocial = $P{AliadoExterno})
  AND ($P{CarreraSolicitada} = 'Todas' OR eg.Titulo = $P{CarreraSolicitada})
GROUP BY oe.RazonSocial, ol.Cargo, ol.FechaHoraOferta
ORDER BY oe.RazonSocial ASC, ol.Cargo ASC;]]></query>
	<field name="aliado" class="java.lang.String"/>
	<field name="vacante" class="java.lang.String"/>
	<field name="postulados" class="java.lang.Long"/>
	<field name="avanzaron" class="java.lang.Long"/>
	<field name="contratados" class="java.lang.Long"/>
	<field name="efectividad" class="java.lang.String"/>
