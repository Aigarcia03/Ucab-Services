<jasperReport name="ReporteTasaOcupacion" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="46686222-5bee-4529-87da-501e93d42050">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="FechaInicio" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-05-01")]]></defaultValueExpression>
	</parameter>
	<parameter name="FechaFin" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-05-31")]]></defaultValueExpression>
	</parameter>
	<parameter name="Sede" class="java.lang.String">
		<defaultValueExpression><![CDATA["Montalbán"]]></defaultValueExpression>
	</parameter>
	<parameter name="TarifaHoraUSD" class="java.lang.Double">
		<defaultValueExpression><![CDATA[Double.valueOf(30.0)]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH BloquesHoras AS (
    SELECT
        ef.nroidentificador,
        ef.direccion,
        ef.nombre,
        ef.tipodemobiliario,
        COALESCE(SUM(EXTRACT(EPOCH FROM (bh.fechahorafin - bh.fechahorainicio)) / 3600.0), 0)::FLOAT AS horas_disp,
        COALESCE(SUM(CASE WHEN bh.disponibilidad = FALSE
                          THEN EXTRACT(EPOCH FROM (bh.fechahorafin - bh.fechahorainicio)) / 3600.0
                          ELSE 0 END), 0)::FLOAT AS horas_reserv
    FROM EspacioFisico ef
    JOIN Edificacion e
        ON ef.direccion = e.direccion AND ef.nombre = e.nombre
    LEFT JOIN BloqueHorario bh
        ON  bh.nroidentificador = ef.nroidentificador
        AND bh.direccion        = ef.direccion
        AND bh.nombre           = ef.nombre
        AND bh.fechahorainicio::date BETWEEN $P{FechaInicio} AND $P{FechaFin}
    WHERE e.ubicacion = $P{Sede}
    GROUP BY ef.nroidentificador, ef.direccion, ef.nombre, ef.tipodemobiliario
),
Calculo AS (
    SELECT
        b.nombre,
        b.tipodemobiliario,
        b.horas_disp,
        b.horas_reserv,
        CASE WHEN b.horas_disp > 0
             THEN ROUND((b.horas_reserv / b.horas_disp * 100)::NUMERIC, 1)::FLOAT
             ELSE 0.0::FLOAT END AS pct_ocupacion,
        ROUND((b.horas_reserv * $P{TarifaHoraUSD})::NUMERIC, 2)::FLOAT AS ingresos
    FROM BloquesHoras b
),
Totales AS (
    SELECT
        CASE WHEN SUM(horas_disp) > 0
             THEN ROUND((SUM(horas_reserv) / SUM(horas_disp) * 100)::NUMERIC, 1)::FLOAT
             ELSE 0.0::FLOAT END AS ocupacion_global,
        COALESCE(SUM(ingresos), 0.0)::FLOAT AS ingresos_total,
        COALESCE((SELECT c2.nombre FROM Calculo c2 ORDER BY c2.ingresos DESC NULLS LAST, c2.nombre ASC LIMIT 1), 'N/A') AS espacio_rentable
    FROM Calculo
)
SELECT
    c.nombre           AS nombre,
    c.tipodemobiliario AS tipo,
    c.horas_disp,
    c.horas_reserv,
    c.pct_ocupacion,
    c.ingresos,
    CASE
        WHEN c.pct_ocupacion = 0  THEN 'Nula'
        WHEN c.pct_ocupacion < 50 THEN 'Baja'
        WHEN c.pct_ocupacion < 75 THEN 'Media'
        ELSE 'Alta'
    END AS estatus,
    t.ocupacion_global,
    t.ingresos_total,
    CAST(t.espacio_rentable AS VARCHAR(100)) AS espacio_rentable
FROM Calculo c
CROSS JOIN Totales t
ORDER BY c.pct_ocupacion DESC, c.nombre ASC;]]></query>
