<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="ReportedeConciliacion" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b1ddef74-2796-4a6b-b996-66c2c0b83e7e">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="FechaInicio" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-01-01")]]></defaultValueExpression>
	</parameter>
	<parameter name="FechaFin" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-12-31")]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH Base AS (
    SELECT
        mp.idmetodo,
        mp.fechahoravigencia::date          AS fecha,
        f.montoacumulado::FLOAT             AS monto_decla,
        mp.montorecibido::FLOAT            AS monto_confir,
        (f.montoacumulado - mp.montorecibido)::FLOAT AS diferencia
    FROM MetodoPago mp
    JOIN Paga    pg ON mp.idmetodo    = pg.idmetodo
    JOIN Factura f  ON pg.numerofactura = f.numero
    WHERE f.fechahoraemision::date BETWEEN $P{FechaInicio} AND $P{FechaFin}
),
Totales AS (
    SELECT
        COALESCE(SUM(monto_decla),  0.0)::FLOAT AS total_declarado,
        COALESCE(SUM(monto_confir), 0.0)::FLOAT AS total_confirmado,
        COALESCE(SUM(diferencia),   0.0)::FLOAT AS total_diferencia
    FROM Base
)
SELECT
    b.idmetodo AS nro_tx,
    b.fecha    AS fecha,
    CASE
        WHEN EXISTS (SELECT 1 FROM PagoPresencial pp JOIN PagoMovil pm ON pp.idpresencial = pm.idpresencial WHERE pp.idmetodo = b.idmetodo) THEN 'Pago Movil'
        WHEN EXISTS (SELECT 1 FROM PagoPresencial pp JOIN Tarjeta   ta ON pp.idpresencial = ta.idpresencial WHERE pp.idmetodo = b.idmetodo) THEN 'Tarjeta'
        WHEN EXISTS (SELECT 1 FROM PagoPresencial pp JOIN TAI       ti ON pp.idpresencial = ti.idpresencial WHERE pp.idmetodo = b.idmetodo) THEN 'TAI'
        WHEN EXISTS (SELECT 1 FROM PagoPresencial pp JOIN Efectivo  ef ON pp.idpresencial = ef.idpresencial WHERE pp.idmetodo = b.idmetodo) THEN 'Efectivo'
        WHEN EXISTS (SELECT 1 FROM TransaccionEnLinea tl JOIN Criptomoneda cr ON tl.idlinea = cr.idlinea WHERE tl.idmetodo = b.idmetodo) THEN 'Criptomoneda'
        WHEN EXISTS (SELECT 1 FROM TransaccionEnLinea tl JOIN Zelle        ze ON tl.idlinea = ze.idlinea WHERE tl.idmetodo = b.idmetodo) THEN 'Zelle'
        WHEN EXISTS (SELECT 1 FROM PagoPresencial    pp WHERE pp.idmetodo = b.idmetodo) THEN 'Presencial'
        WHEN EXISTS (SELECT 1 FROM TransaccionEnLinea tl WHERE tl.idmetodo = b.idmetodo) THEN 'En Linea'
        ELSE 'Otro'
    END AS metodo,
    b.monto_decla,
    b.monto_confir,
    b.diferencia,
    t.total_declarado,
    t.total_confirmado,
    t.total_diferencia
FROM Base b
CROSS JOIN Totales t
ORDER BY b.fecha ASC;]]></query>
