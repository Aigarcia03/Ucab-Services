<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="ReporteBeneficiarios" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="474f12ad-8bf8-48ab-bb93-926e88eb9fe8">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="TipoTrabajador" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<parameter name="Parentesco" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH Detalle AS (
    SELECT
        m.ci,
        (m.primernombre || ' ' || m.primerapellido) AS trabajador,
        (b.primernombre || ' ' || b.primerapellido) AS beneficiario,
        b.parentesco,
        EXTRACT(YEAR FROM AGE(CURRENT_DATE, b.fechanacimiento))::INT AS edad,
        CASE WHEN b.constanciaestudiosuniversitarios IS NULL THEN 'N/A' ELSE 'Registrada' END AS ultima_constancia,
        b.fechafin,
        b.constanciaestudiosuniversitarios,
        CASE
            WHEN EXISTS (SELECT 1 FROM Profesor pr WHERE pr.ci = m.ci)              THEN 'Profesor'
            WHEN EXISTS (SELECT 1 FROM PersonalAdministrativo pa WHERE pa.ci = m.ci) THEN 'Administrativo'
            WHEN EXISTS (SELECT 1 FROM Empleado em WHERE em.ci = m.ci)               THEN 'Empleado'
            ELSE 'Otro'
        END AS tipo_trabajador
    FROM Beneficiario b
    JOIN Registra r ON b.documentoidentidad = r.documentoidentidad
    JOIN Miembro  m ON r.ci = m.ci
),
Filtrado AS (
    SELECT
        d.trabajador,
        d.beneficiario,
        d.parentesco,
        d.edad,
        d.ultima_constancia,
        d.fechafin,
        CASE
            WHEN d.fechafin IS NOT NULL AND d.fechafin < CURRENT_DATE THEN 'Suspendido'
            WHEN d.parentesco IN ('Hijo','Hija') AND d.edad >= 18 AND d.constanciaestudiosuniversitarios IS NULL THEN 'Req. Constancia'
            WHEN d.fechafin IS NOT NULL AND d.fechafin <= CURRENT_DATE + 30 THEN 'Prox. Caducar'
            ELSE 'Activo'
        END AS estatus
    FROM Detalle d
    WHERE ($P{TipoTrabajador} = 'Todos' OR d.tipo_trabajador = $P{TipoTrabajador})
      AND ($P{Parentesco}    = 'Todos' OR d.parentesco      = $P{Parentesco})
),
Totales AS (
    SELECT
        COUNT(*) AS total_registrados,
        COUNT(*) FILTER (WHERE fechafin IS NOT NULL AND fechafin >= CURRENT_DATE AND fechafin <= CURRENT_DATE + 30) AS prox_caducar,
        COUNT(*) FILTER (WHERE fechafin IS NOT NULL AND fechafin <  CURRENT_DATE) AS suspendidos
    FROM Filtrado
)
SELECT
    f.trabajador,
    f.beneficiario,
    f.parentesco,
    f.edad,
    f.ultima_constancia,
    f.estatus,
    t.total_registrados,
    t.prox_caducar,
    t.suspendidos
FROM Filtrado f
CROSS JOIN Totales t
ORDER BY f.trabajador ASC, f.beneficiario ASC;]]></query>
