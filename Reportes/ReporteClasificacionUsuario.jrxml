<jasperReport name="ReporteClasificacionUsuario" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6d9c5791-15b4-4a8a-ae58-49cbacc5a20b">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="RolUsuario" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<parameter name="Clasificacion" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<parameter name="FechaInicio" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2025-09-01")]]></defaultValueExpression>
	</parameter>
	<parameter name="FechaFin" class="java.sql.Date">
		<defaultValueExpression><![CDATA[java.sql.Date.valueOf("2026-01-31")]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH ServCount AS (
    SELECT t.ci, COUNT(*) AS serv_consumido
    FROM Tramite t
    WHERE t.fechacreacion BETWEEN $P{FechaInicio} AND $P{FechaFin}
    GROUP BY t.ci
),
PagoAgg AS (
    SELECT
        f.ci,
        ROUND(AVG(EXTRACT(EPOCH FROM (f.fechahorapago - f.fechahoraemision)) / 86400.0)::NUMERIC, 1)::FLOAT AS prom_dias_pago,
        COALESCE(SUM(f.montoacumulado), 0.0)::FLOAT AS total
    FROM Factura f
    WHERE f.ci IS NOT NULL
      AND f.fechahorapago IS NOT NULL
      AND f.fechahoraemision::date BETWEEN $P{FechaInicio} AND $P{FechaFin}
    GROUP BY f.ci
),
Usuarios AS (
    SELECT
        m.ci,
        (m.primernombre || ' ' || m.primerapellido) AS nombre,
        CASE
            WHEN EXISTS (SELECT 1 FROM Profesor pr WHERE pr.ci = m.ci)               THEN 'Profesor'
            WHEN EXISTS (SELECT 1 FROM PersonalAdministrativo pa WHERE pa.ci = m.ci) THEN 'Administrativo'
            WHEN EXISTS (SELECT 1 FROM Empleado em WHERE em.ci = m.ci)               THEN 'Empleado'
            WHEN EXISTS (SELECT 1 FROM Estudiante es WHERE es.ci = m.ci)             THEN 'Estudiante'
            ELSE 'Miembro'
        END AS rol,
        sc.serv_consumido,
        COALESCE(pa.prom_dias_pago, 0.0)::FLOAT AS prom_dias_pago,
        COALESCE(pa.total, 0.0)::FLOAT AS total,
        CASE
            WHEN pa.prom_dias_pago IS NULL THEN 'Regular'
            WHEN pa.prom_dias_pago <= 10   THEN 'Preferencial'
            ELSE 'Moroso'
        END AS clasificacion
    FROM Miembro m
    JOIN ServCount sc ON m.ci = sc.ci
    LEFT JOIN PagoAgg pa ON m.ci = pa.ci
),
Filtrado AS (
    SELECT u.*
    FROM Usuarios u
    WHERE ($P{RolUsuario}    = 'Todos' OR u.rol           = $P{RolUsuario})
      AND ($P{Clasificacion} = 'Todos' OR u.clasificacion = $P{Clasificacion})
),
Totales AS (
    SELECT
        COUNT(*) FILTER (WHERE clasificacion = 'Preferencial') AS usuarios_preferenciales,
        CASE WHEN COUNT(*) > 0
             THEN ROUND((COUNT(*) FILTER (WHERE serv_consumido >= 2) * 100.0 / COUNT(*))::NUMERIC, 0)::FLOAT
             ELSE 0.0 END AS tasa_recurrencia,
        CASE WHEN SUM(serv_consumido) > 0
             THEN ROUND((SUM(total) / SUM(serv_consumido))::NUMERIC, 2)::FLOAT
             ELSE 0.0 END AS ticket_promedio
    FROM Filtrado
)
SELECT
    f.nombre,
    f.rol,
    f.serv_consumido,
    f.prom_dias_pago,
    f.total,
    f.clasificacion,
    t.usuarios_preferenciales,
    t.tasa_recurrencia,
    t.ticket_promedio
FROM Filtrado f
CROSS JOIN Totales t
ORDER BY f.total DESC, f.nombre ASC;]]></query>
