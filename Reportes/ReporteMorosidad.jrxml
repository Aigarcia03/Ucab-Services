<jasperReport name="ReporteMorosidad" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="13cdb8d6-9c08-4379-8c27-01ba0a505c14">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="Sede" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todas"]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH Morosos AS (
    SELECT
        f.numero,
        f.ci,
        (m.primernombre || ' ' || m.primerapellido) AS nombre,
        f.fechahoraemision::date AS fecha_vencimiento,
        (CURRENT_DATE - f.fechahoraemision::date) AS dias_mora,
        f.deuda::FLOAT AS total,
        COALESCE(f.descripcion, 'N/A') AS servicio,
        s.ubicacion AS sede
    FROM Factura f
    JOIN Miembro m ON f.ci = m.ci
    LEFT JOIN Servicio s ON f.nombrecategoria = s.nombrecategoria
                        AND f.idprestadora   = s.idprestadora
                        AND f.descripcion     = s.descripcion
    WHERE f.estatus = 'pendiente'
      AND f.ci IS NOT NULL
      AND f.fechahoraemision::date < CURRENT_DATE
),
Filtrado AS (
    SELECT * FROM Morosos
    WHERE ($P{Sede} = 'Todas' OR sede = $P{Sede})
),
Totales AS (
    SELECT
        COALESCE(SUM(total), 0.0)::FLOAT AS deuda_acumulada,
        COUNT(*)            AS tramites_mora,
        COUNT(DISTINCT ci)  AS usuarios_morosos
    FROM Filtrado
)
SELECT
    ('V-'   || f.ci)     AS documento,
    f.nombre,
    ('FOL-' || f.numero) AS factura,
    f.fecha_vencimiento,
    f.dias_mora,
    f.total,
    f.servicio,
    CASE WHEN f.dias_mora >= 90 THEN 'Bloqueo de cuenta' ELSE 'Notificar' END AS acciones,
    t.deuda_acumulada,
    t.tramites_mora,
    t.usuarios_morosos
FROM Filtrado f
CROSS JOIN Totales t
ORDER BY f.dias_mora DESC, f.nombre ASC;]]></query>
