<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="ReporteSeguridadAccesos" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a7cdd28e-68f2-4c92-b857-381e17ab49d8">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="RangoDias" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[Integer.valueOf(15)]]></defaultValueExpression>
	</parameter>
	<parameter name="Estatus" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<parameter name="IDUsuario" class="java.lang.String">
		<defaultValueExpression><![CDATA["TODOS"]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH Base AS (
    SELECT s.ci, s.fechainicio, s.ip, s.geolocalizacion, s.uuid,
           s.protocoloproteccion, s.conteointentosfallidos
    FROM Sesion s
    WHERE s.fechainicio >= CURRENT_DATE - $P{RangoDias}
),
Clasif AS (
    SELECT b.*,
        CASE
            WHEN b.protocoloproteccion       THEN 'Bloqueado'
            WHEN b.conteointentosfallidos > 0 THEN 'Fallido'
            ELSE 'Exitoso'
        END AS resultado,
        CASE
            WHEN b.protocoloproteccion         THEN 'Bloqueo preventivo'
            WHEN b.conteointentosfallidos >= 5 THEN 'Advertencia'
            WHEN b.conteointentosfallidos >= 1 THEN 'Registro'
            ELSE 'Ninguna'
        END AS accion
    FROM Base b
),
Filtrado AS (
    SELECT * FROM Clasif c
    WHERE ($P{Estatus}   = 'Todos' OR c.resultado                = $P{Estatus})
      AND ($P{IDUsuario} = 'TODOS' OR CAST(c.ci AS VARCHAR)      = $P{IDUsuario})
),
Totales AS (
    SELECT
        COALESCE(SUM(conteointentosfallidos) FILTER (WHERE fechainicio >= CURRENT_DATE - 1), 0) AS intentos_24h,
        COUNT(DISTINCT ci) FILTER (WHERE protocoloproteccion)                                   AS cuentas_bloqueadas,
        (SELECT HOST(ip) FROM Filtrado GROUP BY ip ORDER BY SUM(conteointentosfallidos) DESC, ip LIMIT 1) AS ip_incidencia
    FROM Filtrado
)
SELECT
    c.fechainicio      AS momento,
    c.ip               AS ip_origen,
    c.uuid,
    c.ci               AS usuario,
    c.geolocalizacion  AS ubicacion,
    c.resultado,
    c.accion,
    t.intentos_24h,
    t.cuentas_bloqueadas,
    COALESCE(t.ip_incidencia, 'N/A') AS ip_incidencia
FROM Filtrado c
CROSS JOIN Totales t
ORDER BY c.fechainicio DESC, c.ci ASC;]]></query>
