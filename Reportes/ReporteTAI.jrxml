<jasperReport name="ReporteTAI" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9bc4eaca-daa6-47c6-985c-7c8f5c8853db">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="Sede" class="java.lang.String">
		<defaultValueExpression><![CDATA["TODAS"]]></defaultValueExpression>
	</parameter>
	<parameter name="Movimientos" class="java.lang.String">
		<defaultValueExpression><![CDATA["Todos"]]></defaultValueExpression>
	</parameter>
	<parameter name="IDUsuario" class="java.lang.String">
		<defaultValueExpression><![CDATA["TODOS"]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[WITH Movimientos AS (
    SELECT
        tai.pos,
        tai.fechahorapago,
        m.ci AS usuario,
        mp.montorecibido::FLOAT AS monto_bruto,
        CASE tai.pos
            WHEN 1 THEN 'Caja'
            WHEN 2 THEN 'Feria'
            WHEN 3 THEN 'Centro de copiado'
            WHEN 4 THEN 'Cafetín'
            ELSE 'POS ' || tai.pos
        END AS lugar
    FROM TAI tai
    JOIN PagoPresencial pp ON tai.idpresencial = pp.idpresencial
    JOIN MetodoPago    mp ON pp.idmetodo       = mp.idmetodo
    JOIN Paga          pg ON mp.idmetodo       = pg.idmetodo
    JOIN Miembro        m ON pg.idcomprador     = m.idcomprador
),
Tipificado AS (
    SELECT mv.*,
        CASE WHEN mv.lugar = 'Caja' THEN 'Recarga' ELSE 'Consumo' END AS tipo,
        CASE WHEN mv.lugar = 'Caja' THEN mv.monto_bruto ELSE -mv.monto_bruto END AS monto_signed
    FROM Movimientos mv
),
Numerado AS (
    SELECT t.*,
        (5000 + ROW_NUMBER() OVER (ORDER BY t.fechahorapago, t.pos)) AS nro_tx,
        SUM(t.monto_signed) OVER (
            PARTITION BY t.usuario
            ORDER BY t.fechahorapago, t.pos
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
        ) AS saldo_resultante
    FROM Tipificado t
),
Totales AS (
    SELECT
        COALESCE(SUM(monto_signed), 0.0)::FLOAT AS saldo_circulante,
        COALESCE(SUM(monto_bruto) FILTER (WHERE tipo = 'Recarga'), 0.0)::FLOAT AS total_recargado,
        (SELECT lugar FROM Tipificado WHERE tipo = 'Consumo' GROUP BY lugar ORDER BY COUNT(*) DESC, lugar LIMIT 1) AS punto_activo
    FROM Tipificado
)
SELECT
    ('TAI-' || n.nro_tx)  AS transaccion,
    ('V-'   || n.usuario) AS usuario,
    n.fechahorapago,
    n.tipo,
    n.lugar,
    n.monto_signed        AS monto,
    n.saldo_resultante,
    tt.saldo_circulante,
    tt.total_recargado,
    COALESCE(tt.punto_activo, 'N/A') AS punto_activo
FROM Numerado n
CROSS JOIN Totales tt
WHERE ($P{Movimientos} = 'Todos' OR n.tipo = $P{Movimientos})
  AND ($P{IDUsuario}   = 'TODOS' OR CAST(n.usuario AS VARCHAR) = $P{IDUsuario})
ORDER BY n.fechahorapago ASC, n.pos ASC;]]></query>
