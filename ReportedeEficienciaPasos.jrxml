<jasperReport name="ReportedeEficienciaPasos" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b1ddef74-2796-4a6b-b996-66c2c0b83e7e">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_ucab"/>
	<parameter name="FechaInicioEficiencia" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd").parse("2026-04-01")]]></defaultValueExpression>
	</parameter>
	<parameter name="FechaFinEficiencia" class="java.util.Date">
		<description><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd").parse("2026-05-15")]]></description>
	</parameter>
	<query language="SQL"><![CDATA[WITH Eficaz AS (
    SELECT pa.ResponsableAsignado AS depto
    FROM PasoActividad pa
    WHERE pa.FechaInicio BETWEEN CAST($P{FechaInicioEficiencia} AS TIMESTAMP) AND CAST($P{FechaFinEficiencia} AS TIMESTAMP)
      AND pa.DuracionReal IS NOT NULL
    ORDER BY ((EXTRACT(EPOCH FROM pa.DuracionReal) / 86400.0) - (pa.DuracionEstimada / 1440.0)) ASC
    LIMIT 1
),
Retraso AS (
    SELECT pa.ResponsableAsignado AS depto
    FROM PasoActividad pa
    WHERE pa.FechaInicio BETWEEN CAST($P{FechaInicioEficiencia} AS TIMESTAMP) AND CAST($P{FechaFinEficiencia} AS TIMESTAMP)
      AND pa.DuracionReal IS NOT NULL
    ORDER BY ((EXTRACT(EPOCH FROM pa.DuracionReal) / 86400.0) - (pa.DuracionEstimada / 1440.0)) DESC
    LIMIT 1
)
SELECT 
    pa.OrdenSecuencial AS nro_tx,
    t.Descripcion AS tip_tramite,
    pa.ResponsableAsignado AS depto,
    pa.FechaInicio AS fecha_inicio,
    
    ROUND((pa.DuracionEstimada / 1440.0)::NUMERIC, 1)::FLOAT AS tiempo_esperado,
    ROUND((EXTRACT(EPOCH FROM pa.DuracionReal) / 86400.0)::NUMERIC, 1)::FLOAT AS tiempo_real,
    ROUND(((EXTRACT(EPOCH FROM pa.DuracionReal) / 86400.0) - (pa.DuracionEstimada / 1440.0))::NUMERIC, 1)::FLOAT AS desviacion,
    
    CAST((SELECT depto FROM Eficaz) AS VARCHAR(100)) AS dpto_mas_eficaz,
    CAST((SELECT depto FROM Retraso) AS VARCHAR(100)) AS dpto_mayor_retraso
FROM Tramite t
JOIN PasoActividad pa ON t.CI = pa.CI 
    AND t.IDPrestadora = pa.IDPrestadora 
    AND t.NombreCategoria = pa.NombreCategoria 
    AND t.Descripcion = pa.Descripcion 
    AND t.FechaCreacion = pa.FechaCreacion
WHERE pa.FechaInicio BETWEEN CAST($P{FechaInicioEficiencia} AS TIMESTAMP) AND CAST($P{FechaFinEficiencia} AS TIMESTAMP)
  AND pa.DuracionReal IS NOT NULL
ORDER BY pa.FechaInicio ASC;]]></query>
